  "privacyDocReferenceIntro": {
    "message": "StorePilot Chrome Web Store ಗೌಪ್ಯತೆ ಕ್ಷೇತ್ರಗಳಿಗಾಗಿ ಒಂದು ಪ್ರಾಜೆಕ್ಟ್ ಡಾಕ್ಯುಮೆಂಟ್ ಅನ್ನು ಸ್ಕ್ಯಾನ್ ಮಾಡಬಹುದು. ಈ ಅಂಗೀಕೃತ ಕೀಗಳನ್ನು ಬಳಸಿ ಸ್ಕ್ಯಾನರ್ ಊಹಿಸದೆ ಪಠ್ಯವನ್ನು ರೂಟ್ ಮಾಡಬಹುದು."
  },
  "privacyDocPermissionRule": {
    "message": "ಅನುಮತಿ ಸಮರ್ಥನೆಗಳಿಗಾಗಿ, permission.<manifest permission code> ಬಳಸಿ. ಪ್ರತ್ಯಯವು ನಿಮ್ಮ ಮ್ಯಾನಿಫೆಸ್ಟ್ ಅನುಮತಿಗಳಲ್ಲಿನ ಕೋಡ್ಗೆ ಹೊಂದಿಕೆಯಾಗಬೇಕು, optional_permissions, host_permissions, ಅಥವಾ content_scripts.matches."
  },
  "privacyDocNamingGuideline": {
    "message": "ಶಿಫಾರಸು ಮಾಡಲಾದ ಫೈಲ್ ಹೆಸರುಗಳು: docs/chrome-web-store-privacy-form.md ಅಥವಾ STORE_JUSTIFICATIONS.md. ವಿಷಯವು [privacy] ಬ್ಲಾಕ್, ಅಂಗೀಕೃತ ಕೀಗಳು ಅಥವಾ ಗುರುತಿಸಬಹುದಾದ ಅಂಗಡಿ-ಸಮರ್ಥನೆ ಶೀರ್ಷಿಕೆಗಳನ್ನು ಹೊಂದಿರುವಾಗ StorePilot ಇತರ.md ಅಥವಾ.txt ಫೈಲ್ಗಳನ್ನು ಸಹ ಸ್ವೀಕರಿಸುತ್ತದೆ."
