  "privacyDocReferenceIntro": {
    "message": "StorePilot יכול לסרוק מסמך פרויקט אחד עבור Chrome Web Store שדות פרטיות. השתמש במפתחות קנוניים אלה כדי שהסורק יוכל לנתב טקסט מבלי לנחש."
  },
  "privacyDocPermissionRule": {
    "message": "להצדקות הרשאות, השתמש ב-permission.<manifest permission code>. הסיומת צריכה להתאים לקוד בהרשאות המניפסט שלך, optional_permissions, host_permissions או content_scripts.matches."
  },
  "privacyDocNamingGuideline": {
    "message": "שמות קבצים מומלצים: docs/chrome-web-store-privacy-form.md או STORE_JUSTIFICATIONS.md. StorePilot מקבל גם קבצי.md או.txt אחרים כאשר התוכן מכיל בלוק [privacy], מפתחות קנוניים או כותרות הצדקה לחנות הניתנות לזיהוי."
  },
