  "privacyDocReferenceIntro": {
    "message": "StorePilot voi skannata yhden projektidokumentin Chrome Web Store tietosuojakenttään. Käytä näitä kanonisia näppäimiä, jotta skanneri voi reitittää tekstiä arvaamatta."
  },
  "privacyDocPermissionRule": {
    "message": "Käytä lupien perusteluja permission.<manifest permission code>. Loppuliitteen tulee vastata luettelon käyttöoikeuksissasi olevaa koodia optional_permissions, host_permissions tai content_scripts.matches."
  },
  "privacyDocNamingGuideline": {
    "message": "Suositellut tiedostonimet: docs/chrome-web-store-privacy-form.md tai STORE_JUSTIFICATIONS.md. StorePilot hyväksyy myös muut.md- tai.txt-tiedostot, kun sisältö sisältää [privacy]-lohkon, ensisijaiset avaimet tai tunnistettavat kaupan perusteluotsikot."
  },
